APP_PORT=8080
APP_TODO_BASE_URL=http://localhost:8080
APP_TODO_DEEP_LINK_PATTERN=http://localhost:4200/todos/%d
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200
APP_WEBSOCKET_ALLOWED_ORIGINS=http://localhost:4200
APP_TODO_OVERDUE_HOURS=24
APP_MAIL_FROM=
APP_RATE_LIMIT_ENABLED=false
APP_RATE_LIMIT_REQUESTS_PER_WINDOW=300
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_RATE_LIMIT_PATHS=/api/v1/

POSTGRES_DB=todo
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_PORT=5432

# Gmail SMTP Configuration for Development
# Replace with your actual Gmail credentials

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-gmail@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# Enable mail sending
APP_MAIL_ENABLED=true

# Mail properties
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Instructions:
# 1. Replace 'your-gmail@gmail.com' with your actual Gmail address
# 2. Replace 'your-app-password' with your Gmail App Password
# 3. To create an App Password:
#    - Go to Google Account settings
#    - Security → 2-Step Verification → App passwords
#    - Create a new app password for "Mail"
#    - Use that 16-character password here
# 4. Copy this file to .env and update with your credentials
# 5. The application will automatically load these credentials

SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SERVER_FORWARD_HEADERS_STRATEGY=none
SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_HEALTH_MAIL_ENABLED=false
LOGGING_FILE_NAME=
LOGGING_ROLLING_MAX_FILE_SIZE=10MB
LOGGING_ROLLING_MAX_HISTORY=14
